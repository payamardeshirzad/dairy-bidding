{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "auctions-active-route": {
        "ClusterId": "auction-cluster",
        "Match": { "Path": "/auctions/active", "Methods": [ "GET" ] }
      },
      "auction-detail-route": {
        "ClusterId": "auction-cluster",
        "Match": { "Path": "/auctions/{id}", "Methods": [ "GET" ] }
      },
      "bid-history-route": {
        "ClusterId": "bidding-cluster",
        "Match": { "Path": "/auctions/{auctionId}/bids", "Methods": [ "GET" ] }
      },
      "highest-bid-route": {
        "ClusterId": "bidding-cluster",
        "Match": { "Path": "/auctions/{auctionId}/highest-bid", "Methods": [ "GET" ] }
      },
      "place-bid-route": {
        "ClusterId": "bidding-cluster",
        "Match": { "Path": "/bids", "Methods": [ "POST" ] }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-1": { "Address": "http://localhost:5245/" }
        }
      },
      "auction-cluster": {
        "Destinations": {
          "auction-1": { "Address": "http://localhost:5255/" }
        }
      },
      "bidding-cluster": {
        "Destinations": {
          "bidding-1": { "Address": "http://localhost:5170/" }
        }
      }
    }
  }
}
