# build
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_GATEWAY_BASE_URL=http://localhost:5000
ARG VITE_AUTH_STORAGE_MODE=localStorage
ENV VITE_GATEWAY_BASE_URL=$VITE_GATEWAY_BASE_URL
ENV VITE_AUTH_STORAGE_MODE=$VITE_AUTH_STORAGE_MODE
RUN npm run build

# runtime
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80